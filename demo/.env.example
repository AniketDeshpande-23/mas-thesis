# Ollama URL — use the pod that HAS a model pulled (e.g. prof's pod, NOT your own)
# Format: https://<hub-url>/user/<username-with-ollama>/proxy/11434
OLLAMA_BASE_URL=https://jupyterhub.ki-awz.iisys.de/user/tbuchmann@hof-university.de/proxy/11434

# YOUR JupyterHub token (not the pod owner's) — File > Hub Control Panel > Token > Request new API token
JUPYTERHUB_TOKEN=<paste-your-token-here>

OTEL_SDK_DISABLED=true
