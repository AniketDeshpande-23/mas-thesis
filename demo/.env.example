# ── Ollama on the JupyterHub pod ────────────────────────────────────────
#
# The proxy URL follows this pattern:
#   https://<hub-url>/user/<your-username>/proxy/11434
#
# How to find it:
#   1. Log in to JupyterHub in your browser
#   2. Look at the URL bar — it shows: https://<hub-url>/user/<username>/...
#   3. Replace the path at the end with /proxy/11434
#
OLLAMA_BASE_URL=https://<hub-url>/user/<username>/proxy/11434

# ── JupyterHub authentication token ─────────────────────────────────────
#
# How to get your token:
#   1. In JupyterHub, go to File > Hub Control Panel
#   2. Click "Token" in the top menu
#   3. Click "Request new API token"
#   4. Copy the token and paste it below
#
JUPYTERHUB_TOKEN=<paste-token-here>

# ── Disable CrewAI telemetry ─────────────────────────────────────────────
# Prevents DNS lookup errors on university networks
OTEL_SDK_DISABLED=true
