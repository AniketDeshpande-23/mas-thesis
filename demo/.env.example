# JupyterHub Ollama endpoint — replace <your-username> with your university login
OLLAMA_BASE_URL=https://jupyterhub.ki-awz.iisys.de/user/<your-username>@hof-university.de/proxy/11434

# API token — JupyterHub > File > Hub Control Panel > Token > Request new API token
JUPYTERHUB_TOKEN=<your-token>

OTEL_SDK_DISABLED=true
